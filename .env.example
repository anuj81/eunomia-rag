# Copy to .env and fill in real values. .env is gitignored.

# OpenMetadata source credentials (used by the indexer)
OPENMETADATA_PASSWORD=admin

# Bearer token clients (the middleware) present to this service
RAG_API_KEY=

# Optional: override config file path
# EUNOMIA_RAG_CONFIG=config/eunomia-rag.local.yaml

# Any field can be overridden via EUNOMIA_RAG_<SECTION>__<FIELD>:
#   EUNOMIA_RAG_LOGGING__LEVEL=DEBUG
#   EUNOMIA_RAG_QDRANT__URL=http://qdrant.internal:6333
#   EUNOMIA_RAG_AUTH__REQUIRE_AUTH=false
